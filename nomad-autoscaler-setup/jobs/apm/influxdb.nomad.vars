# APM: InfluxDB 1.x (via Telegraf)
# Requires: InfluxDB 1.x running on prometheus-vm:8086
# Autoscaler config: username=autoscaler, shared_secret=nomad-autoscaler-secret

apm_source   = "influxdb"
apm_query    = "SELECT mean(\"usage_idle\") FROM \"cpu\" WHERE \"cpu\"='cpu-total' AND time > now() - 1m GROUP BY host"
scale_target = 50
