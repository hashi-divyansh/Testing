# APM: InfluxDB 1.x (via Telegraf)
# Requires: influxdb + telegraf backend jobs running (make deploy-backend APM=influxdb)
# Deploy:   make deploy-webapp APM=influxdb
#
# Query returns mean CPU user % across the last 1 minute for all hosts.
# Autoscaler scales up when mean exceeds scale_target (50%).

apm_source   = "influxdb"
apm_query    = "SELECT mean(\"usage_user\") FROM \"cpu\" WHERE \"cpu\"='cpu-total' AND time > now() - 1m"
scale_target = 50
